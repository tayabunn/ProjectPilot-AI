# Root-level gitignore for ProjectPilot AI

# Node
node_modules/

# Environment files — NEVER commit secrets
.env
.env.*
!.env.example

# Build outputs
dist/
build/
.next/
out/

# Uploads
uploads/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Vercel
.vercel

# TypeScript build info
*.tsbuildinfo

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/settings.json
